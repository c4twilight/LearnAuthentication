  },
  "item": [
    {
      "name": "Auth - Save User",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Content-Type", "value": "application/json" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"username\": \"{{username}}\",\n  \"password\": \"{{password}}\",\n  \"roles\": [\n    {\n      \"id\": 1,\n      \"name\": \"ADMIN\"\n    }\n  ]\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/api/v1/save",
          "host": ["{{baseUrl}}"],
          "path": ["api", "v1", "save"]
        }
      }
    },
    {
      "name": "Auth - Login",
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('status is 200', function () { pm.response.to.have.status(200); });",
              "var jsonData = pm.response.json();",
              "if (jsonData.accessToken) { pm.environment.set('accessToken', jsonData.accessToken); }",
              "if (jsonData.token) { pm.environment.set('refreshToken', jsonData.token); }"
            ]
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          { "key": "Content-Type", "value": "application/json" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"username\": \"{{username}}\",\n  \"password\": \"{{password}}\"\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/api/v1/login",
          "host": ["{{baseUrl}}"],
          "path": ["api", "v1", "login"]
        }
      }
    },
    {
      "name": "Auth - Refresh Token",
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('status is 200', function () { pm.response.to.have.status(200); });",
              "var jsonData = pm.response.json();",
              "if (jsonData.accessToken) { pm.environment.set('accessToken', jsonData.accessToken); }",
              "if (jsonData.token) { pm.environment.set('refreshToken', jsonData.token); }"
            ]
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          { "key": "Content-Type", "value": "application/json" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"token\": \"{{refreshToken}}\"\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/api/v1/refreshToken",
          "host": ["{{baseUrl}}"],
          "path": ["api", "v1", "refreshToken"]
        }
      }
    },
